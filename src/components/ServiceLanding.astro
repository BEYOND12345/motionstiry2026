---
import VimeoEmbed from './VimeoEmbed';

export interface WorkItem {
  title: string;
  link: string;
  vimeoId: string;
}

export interface FaqItem {
  label: string;
  body: string;
}

export interface CrossLink {
  href: string;
  eyebrow: string;
  label: string;
}

export interface RelatedReading {
  href: string;
  label: string;
}

interface Props {
  eyebrow: string;
  /** Headline lines — each becomes a line break on md+ */
  headline: string[];
  lede: string;
  work: WorkItem[];
  moreWork?: WorkItem[];
  quote?: string;
  quoteBy?: string;
  quoteRole?: string;
  faqs?: FaqItem[];
  links?: CrossLink[];
  relatedReading?: RelatedReading[];
}

const {
  eyebrow,
  headline,
  lede,
  work,
  moreWork = [],
  quote,
  quoteBy,
  quoteRole,
  faqs = [],
  links = [],
  relatedReading = [],
} = Astro.props;

const [featured, ...rest] = work;

const clients = ['United Nations', 'TransferWise', 'Atomic', 'Mosaic', 'RSPCA', 'Meltwater'];

const credentials = [
  {
    label: 'Full pipeline',
    body: 'Concept, storyboard, design, illustration, and animation — one senior maker throughout. No account managers. No handoffs.',
  },
  {
    label: 'Story first',
    body: 'Creative built for completion and clarity. If it is not a strong story, people do not watch to the end — and the metrics show it.',
  },
  {
    label: 'Career depth',
    body: 'United Nations. TransferWise\'s first video, working directly with their CEO. 1,000+ films. Motion design is all I have ever done.',
  },
];
---

<div class="landing">
  <header class="landing-hero">
    <span class="landing-eyebrow landing-reveal" style="--d: 0">{eyebrow}</span>
    <h1 class="landing-title landing-reveal" style="--d: 1">
      {headline.map((line, i) => (
        <>
          {i > 0 && (
            <>
              {' '}
              <br class="hidden md:block" />
            </>
          )}
          {line}
        </>
      ))}
    </h1>
    <p class="landing-lede landing-reveal" style="--d: 2">{lede}</p>
  </header>

  <section id="selected-work" class="landing-section landing-reveal" style="--d: 3">
    <div class="landing-section-head">
      <span class="landing-eyebrow">Selected Work</span>
      <span class="landing-eyebrow landing-count">{String(work.length + moreWork.length).padStart(2, '0')}</span>
    </div>

    <p class="landing-clients landing-reveal" style="--d: 3">
      {clients.join(' · ')}
    </p>

    {featured && (
      <article class="landing-featured group">
        <span class="landing-work-index">01</span>
        <VimeoEmbed
          client:visible
          vimeoId={featured.vimeoId}
          title={featured.title}
          loading="eager"
          autoColor={true}
          className="landing-featured-media"
        />
        <a href={featured.link} class="landing-work-meta">
          <h2 class="landing-featured-title">{featured.title}</h2>
          <span class="landing-work-link">View case study →</span>
        </a>
      </article>
    )}

    {quote && (
      <figure class="landing-proof">
        <blockquote class="landing-proof-quote">“{quote}”</blockquote>
        {(quoteBy || quoteRole) && (
          <figcaption class="landing-proof-cap">
            {quoteBy && <span class="landing-proof-by">{quoteBy}</span>}
            {quoteRole && <span class="landing-proof-role">{quoteRole}</span>}
          </figcaption>
        )}
      </figure>
    )}

    {rest.length > 0 && (
      <div class="landing-work-grid">
        {rest.map((study, i) => (
          <article class="landing-work-card group">
            <span class="landing-work-index">{String(i + 2).padStart(2, '0')}</span>
            <VimeoEmbed
              client:visible
              vimeoId={study.vimeoId}
              title={study.title}
              loading="lazy"
              autoColor={true}
              className="landing-work-media"
            />
            <a href={study.link} class="landing-work-meta">
              <h2 class="landing-work-title">{study.title}</h2>
              <span class="landing-work-link">View case study →</span>
            </a>
          </article>
        ))}
      </div>
    )}

    {moreWork.length > 0 && (
      <div class="landing-more-grid">
        {moreWork.map((study) => (
          <a href={study.link} class="landing-more-card group">
            <div class="landing-more-thumb">
              <img
                src={`https://vumbnail.com/${study.vimeoId}.jpg`}
                alt={study.title}
                loading="lazy"
              />
            </div>
            <h3 class="landing-more-title">{study.title}</h3>
          </a>
        ))}
      </div>
    )}

    <p class="landing-all-work landing-all-work--end">
      <a href="/work/">See all work →</a>
    </p>
  </section>

  <section class="landing-section">
    <span class="landing-eyebrow landing-section-label">Why the work lasts</span>
    <div class="landing-cred">
      {credentials.map((item) => (
        <div class="landing-cred-row">
          <h3 class="landing-cred-label">{item.label}</h3>
          <p class="landing-cred-body">{item.body}</p>
        </div>
      ))}
    </div>
  </section>

  {faqs.length > 0 && (
    <section class="landing-section">
      <span class="landing-eyebrow landing-section-label">Questions</span>
      <div class="landing-faq">
        {faqs.map((faq) => (
          <div class="landing-faq-row">
            <h3 class="landing-faq-label">{faq.label}</h3>
            <p class="text-body">{faq.body}</p>
          </div>
        ))}
      </div>
    </section>
  )}

  {relatedReading.length > 0 && (
    <section class="landing-section">
      <span class="landing-eyebrow landing-section-label">Related reading</span>
      <div class="landing-cred">
        {relatedReading.map((item) => (
          <a href={item.href} class="landing-cred-row group" style="text-decoration: none; color: inherit;">
            <h3 class="landing-cred-label group-hover:opacity-55 transition-opacity">{item.label} →</h3>
            <p class="landing-cred-body">From the Motion Story blog</p>
          </a>
        ))}
      </div>
    </section>
  )}

  {links.length > 0 && (
    <nav class="landing-links" aria-label="Related pages">
      {links.map((link) => (
        <a href={link.href} class="landing-link-card group">
          <span class="landing-eyebrow mb-4 block">{link.eyebrow}</span>
          <p class="landing-link-label">{link.label}</p>
        </a>
      ))}
    </nav>
  )}
</div>
