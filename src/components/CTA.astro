---
interface Props {
  heading?: string;
  label?: string;
}

const { heading = "Got something complex to explain?", label = "Start a Project" } = Astro.props;
---

<section class="border-t border-black/10 bg-black/[0.01]">
  <div class="max-w-6xl mx-auto px-8 py-32 text-center">
    <span class="text-metadata mb-8 block">{label}</span>
    <h2 class="font-display text-3xl md:text-6xl font-bold tracking-tight mb-12">
      {heading}
    </h2>
    <a
      href="mailto:daniel@motionstory.com.au?subject=Project%20enquiry"
      class="font-display text-lg md:text-2xl font-bold tracking-tight border-b border-black/20 pb-2 hover:border-black transition-colors"
    >
      Email Dan →
    </a>
  </div>
</section>
