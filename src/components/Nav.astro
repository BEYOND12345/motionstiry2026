---
interface Props {
  activeItem?: string;
}

const { activeItem } = Astro.props;
const items = [
  { label: "Work", href: "/work/" },
  { label: "Process", href: "/process/" },
  { label: "About", href: "/about/" },
  { label: "Blog", href: "/blog/" },
  { label: "Start a Project", href: "/contact/" },
];
---

<div transition:name="site-nav" transition:persist>
  <a href="#main-content" class="sr-only focus:not-sr-only focus:fixed focus:top-2 focus:left-2 focus:z-[100] focus:bg-black focus:text-white focus:px-4 focus:py-2 focus:text-sm">Skip to content</a>
  <!-- Nav bar -->
  <nav class="fixed top-0 left-0 right-0 z-50 border-b border-black/5" id="nav-bar" aria-label="Main navigation">
    <div class="absolute inset-0 bg-white/90 backdrop-blur-sm" id="nav-bg"></div>
    <div class="relative max-w-7xl mx-auto px-6 md:px-8 py-5 flex items-center justify-between">
      <a href="/" class="font-display text-xl font-bold tracking-tight hover:opacity-70 transition-opacity" id="nav-logo">
        Motion Story.
      </a>

      <!-- Desktop nav -->
      <div class="hidden md:flex items-center gap-10">
        {items.map(item => (
          <a
            href={item.href}
            class:list={[
              "text-top-nav transition-colors",
              activeItem === item.label ? "text-black" : "hover:text-black"
            ]}
            aria-current={activeItem === item.label ? "page" : undefined}
          >
            {item.label}
          </a>
        ))}
      </div>

      <!-- Mobile hamburger button -->
      <button
        class="md:hidden flex flex-col justify-center items-center w-11 h-11 gap-1.5 relative z-10"
        id="mobile-menu-btn"
        aria-label="Open menu"
        aria-expanded="false"
        aria-controls="mobile-menu"
      >
        <span class="hamburger-line w-6 h-px bg-black transition-all duration-300 origin-center"></span>
        <span class="hamburger-line w-6 h-px bg-black transition-all duration-300 origin-center"></span>
      </button>
    </div>
  </nav>

  <!-- Mobile menu (inside persist boundary, but outside backdrop-blur element) -->
  <div
    id="mobile-menu"
    class="md:hidden fixed inset-0 top-[69px] bg-black text-white z-40 flex flex-col px-6 py-10 transform translate-x-full transition-transform duration-300 ease-[cubic-bezier(0.16,1,0.3,1)]"
    aria-hidden="true"
  >
    {items.map(item => (
      <a
        href={item.href}
        class:list={[
          "font-display text-3xl font-medium tracking-tight py-4 border-b border-white/10 transition-opacity",
          activeItem === item.label ? "opacity-100" : "opacity-50 hover:opacity-100"
        ]}
        aria-current={activeItem === item.label ? "page" : undefined}
      >
        {item.label}
      </a>
    ))}
    <div class="mt-auto pt-8">
      <a href="mailto:daniel@motionstory.com.au" class="text-body !text-white/50">daniel@motionstory.com.au</a>
    </div>
  </div>
</div>

<script>
  document.addEventListener('astro:page-load', () => {
    const btn = document.getElementById('mobile-menu-btn');
    const menu = document.getElementById('mobile-menu');
    const navBar = document.getElementById('nav-bar');
    const navBg = document.getElementById('nav-bg');
    const navLogo = document.getElementById('nav-logo');
    if (!btn || !menu) return;

    const lines = btn.querySelectorAll('.hamburger-line');

    function openMenu() {
      menu!.classList.remove('translate-x-full');
      menu!.classList.add('translate-x-0');
      btn!.setAttribute('aria-expanded', 'true');
      btn!.setAttribute('aria-label', 'Close menu');
      menu!.setAttribute('aria-hidden', 'false');
      lines[0]?.classList.add('rotate-45', 'translate-y-[4px]', '!bg-white');
      lines[1]?.classList.add('-rotate-45', '-translate-y-[4px]', '!bg-white');
      navBg?.classList.remove('bg-white/90');
      navBg?.classList.add('bg-black');
      navBar?.classList.remove('border-black/5');
      navBar?.classList.add('border-white/10');
      navLogo?.classList.add('text-white');
      document.body.style.overflow = 'hidden';
    }

    function closeMenu() {
      menu!.classList.add('translate-x-full');
      menu!.classList.remove('translate-x-0');
      btn!.setAttribute('aria-expanded', 'false');
      btn!.setAttribute('aria-label', 'Open menu');
      menu!.setAttribute('aria-hidden', 'true');
      lines[0]?.classList.remove('rotate-45', 'translate-y-[4px]', '!bg-white');
      lines[1]?.classList.remove('-rotate-45', '-translate-y-[4px]', '!bg-white');
      navBg?.classList.add('bg-white/90');
      navBg?.classList.remove('bg-black');
      navBar?.classList.add('border-black/5');
      navBar?.classList.remove('border-white/10');
      navLogo?.classList.remove('text-white');
      document.body.style.overflow = '';
    }

    btn.addEventListener('click', () => {
      const isOpen = menu!.classList.contains('translate-x-0');
      if (isOpen) closeMenu();
      else openMenu();
    });

    menu.querySelectorAll('a').forEach(link => {
      link.addEventListener('click', closeMenu);
    });
  });
</script>
