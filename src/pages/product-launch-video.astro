---
import BaseLayout from '../layouts/BaseLayout.astro';
import LandingPage from '../components/LandingPage/LandingPage';
import { productLaunchLanding } from '../data/landing-pages/product-launch';
import '../styles/global.css';

const config = productLaunchLanding;

const serviceSchema = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  name: 'Product Launch Videos That Land',
  description: config.seo.metaDescription,
  provider: { '@type': 'Organization', name: 'Motion Story', url: 'https://motionstory.com.au' },
  serviceType: 'Product Launch Video Production',
  areaServed: 'Worldwide',
};

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: config.faq.items.map((f) => ({
    '@type': 'Question',
    name: f.question,
    acceptedAnswer: { '@type': 'Answer', text: f.answer },
  })),
};
---

<BaseLayout
  title={config.seo.titleTag}
  description={config.seo.metaDescription}
  canonicalUrl={`https://motionstory.com.au${config.seo.canonicalPath}`}
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(serviceSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
    <!-- TODO(dan): Replace with live GA4 + Google Ads IDs -->
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      window.gtag = gtag;
      // gtag('js', new Date());
      // gtag('config', 'G-XXXXXXXX');
      // gtag('config', 'AW-XXXXXXXX');
    </script>
  </Fragment>

  <LandingPage client:load config={config} />
</BaseLayout>
