---
import PageLayout from '../layouts/PageLayout.astro';

const structuredData = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  "name": "How I Work | Motion Design Process | Motion Story",
  "url": "https://motionstory.com.au/process/",
  "description": "The process that turns complex briefs into clear motion design. Three phases. No wasted time. Dan Neale, Motion Story.",
  "speakable": {
    "@type": "SpeakableSpecification",
    "cssSelector": ["h1", ".text-body"]
  }
};

const faqs = [
  {
    q: "How much does a project cost?",
    a: "From $5,000. Most projects land around $10,000–$15,000. Fixed quote upfront after we understand the brief — no cookie-cutter packages.",
  },
  {
    q: "How long does a typical motion design project take?",
    a: "Most projects run 4 to 8 weeks from kickoff to final delivery. Phase one (script and concept) usually takes 1 to 2 weeks. Phase two (storyboard and style frames) takes about 2 weeks. Phase three (animation, sound, revisions) takes another 2 to 4 weeks. Tight timelines are possible for simpler pieces — I'll always be upfront about what's realistic and what's not.",
  },
  {
    q: "How many rounds of revisions do I get?",
    a: "Two structured revision rounds during animation, plus one structured review after storyboard and style frames. The structure matters: feedback is consolidated, not drip-fed, so the project keeps momentum. Scope changes mid-project are handled transparently — if they push timeline or cost, you'll know before any work starts.",
  },
  {
    q: "What do I need to provide to get started?",
    a: "Not a script. Just context. Who are you, who are you trying to reach, what do you want them to do next, and what's getting in the way right now. If you have a brand guide, existing decks, screenshots, or competitor references, those help. If you don't, we build the brief together in phase one.",
  },
  {
    q: "Who will I actually be working with?",
    a: "Me. Daniel Neale. I write the concepts, design the frames, illustrate, animate the final piece, and respond to your feedback directly. No account managers, no handoffs to junior animators. That end-to-end craft is the model — 1,000+ films into a career spent entirely in motion.",
  },
  {
    q: "Can you work to a fixed deadline?",
    a: "Yes, if the timeline is realistic for the scope. I'll be honest early in the conversation about whether a date is achievable. If it's tight, we can sometimes reduce scope (shorter runtime, simpler visual direction, fewer revisions) to hit the date without cutting corners on the things that matter.",
  },
  {
    q: "Do you offer ongoing motion design or retainer work?",
    a: "Yes. A lot of SaaS and product-led clients work with me on a rolling basis — a series of feature videos, social cutdowns, quarterly updates, or ongoing campaign motion. After the first project ships, we can set up a lightweight retainer or book work project-by-project, whichever suits.",
  },
];

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqs.map((f) => ({
    "@type": "Question",
    "name": f.q,
    "acceptedAnswer": { "@type": "Answer", "text": f.a },
  })),
};
---

<PageLayout
  title="How I Work | Motion Design Process | Motion Story"
  description="The process that turns complex briefs into clear motion design. Three phases. From $5,000. Dan Neale, Motion Story."
  activeNav="Process"
  showCTA={false}
  floatSubject="Motion design process"
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(structuredData)} />
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org", "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://motionstory.com.au/" },
        { "@type": "ListItem", "position": 2, "name": "Process", "item": "https://motionstory.com.au/process/" }
      ]
    })} />
    <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  </Fragment>

  <div class="pt-32 pb-24 px-8 max-w-5xl mx-auto">
    <span class="text-metadata mb-8 block">Process</span>
    <h1 class="font-display text-4xl md:text-8xl font-bold tracking-tight leading-[0.85] mb-16">
      The process isn't<br />complicated. The<br />clarity is.
    </h1>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-16 mb-32">
      <div>
        <p class="text-body text-lg leading-relaxed">
          Most projects fail before a single frame is animated. The brief is wrong. The message is buried. There's no clear point of view. Here's how I stop that from happening.
        </p>
      </div>
    </div>

    <!-- Phases -->
    <div class="space-y-32 mb-32">

      <!-- Phase 01 -->
      <section>
        <span class="text-metadata mb-4 block text-accent">01</span>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-16">
          <div>
            <h2 class="font-display text-3xl font-bold tracking-tight mb-8">Challenge the brief.</h2>
            <p class="text-body text-lg leading-relaxed">
              Before we talk about visuals, we talk about substance. What does this piece actually need to do? Who watches it, where, and what decision do they make afterwards? Most clients come in thinking they know what they want. Some of them are right. My job is to find out which, and redirect before we've spent anything.
            </p>
          </div>
          <div>
            <p class="text-metadata mb-4">What happens here</p>
            <ul class="space-y-3">
              <li class="text-body text-lg leading-relaxed">Discovery session: me asking hard questions</li>
              <li class="text-body text-lg leading-relaxed">Script and concept: one clear direction, not three options</li>
              <li class="text-body text-lg leading-relaxed">Voice and tone direction</li>
              <li class="text-body text-lg leading-relaxed">Visual style reference</li>
            </ul>
          </div>
        </div>
      </section>

      <!-- Phase 02 -->
      <section>
        <span class="text-metadata mb-4 block text-accent">02</span>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-16">
          <div>
            <h2 class="font-display text-3xl font-bold tracking-tight mb-8">Build the visual argument.</h2>
            <p class="text-body text-lg leading-relaxed">
              This is where the script becomes something you can see. Not a dozen revision rounds. Not mood boards for mood boards' sake. One clear visual direction, agreed early, built with precision. The hard decisions get made here, before animation makes them expensive.
            </p>
          </div>
          <div>
            <p class="text-metadata mb-4">What gets built</p>
            <ul class="space-y-3">
              <li class="text-body text-lg leading-relaxed">Storyboard (rough → refined)</li>
              <li class="text-body text-lg leading-relaxed">Style frame design</li>
              <li class="text-body text-lg leading-relaxed">Motion direction: how things move, not just how they look</li>
              <li class="text-body text-lg leading-relaxed">One structured feedback round before production begins</li>
            </ul>
          </div>
        </div>
      </section>

      <!-- Phase 03 -->
      <section>
        <span class="text-metadata mb-4 block text-accent">03</span>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-16">
          <div>
            <h2 class="font-display text-3xl font-bold tracking-tight mb-8">Animate. Refine. Ship.</h2>
            <p class="text-body text-lg leading-relaxed">
              Production. The part most people think is the whole job. By this point, the hard decisions are made. Animation is execution, and it moves fast when the earlier phases did their job properly.
            </p>
          </div>
          <div>
            <p class="text-metadata mb-4">What gets delivered</p>
            <ul class="space-y-3">
              <li class="text-body text-lg leading-relaxed">Full animation production</li>
              <li class="text-body text-lg leading-relaxed">Sound design and voiceover integration</li>
              <li class="text-body text-lg leading-relaxed">Two structured revision rounds</li>
              <li class="text-body text-lg leading-relaxed">Final delivery in your required format (web, social, pitch, embed)</li>
            </ul>
          </div>
        </div>
      </section>

    </div>

    <!-- FAQ -->
    <section class="mb-32 pb-32 border-b border-black/10">
      <span class="text-metadata mb-10 block">Frequently Asked Questions</span>
      <h2 class="font-display text-3xl md:text-5xl font-bold tracking-tight leading-[0.9] mb-16">
        Common questions<br />about the process.
      </h2>
      <div class="space-y-12">
        {faqs.map((faq) => (
          <div class="grid grid-cols-1 md:grid-cols-3 gap-8 items-start pb-12 border-b border-black/10 last:border-b-0 last:pb-0">
            <div>
              <h3 class="font-display text-lg font-medium tracking-tight">{faq.q}</h3>
            </div>
            <div class="md:col-span-2">
              <p class="text-body">{faq.a}</p>
            </div>
          </div>
        ))}
      </div>
    </section>

    <!-- CTA -->
    <section class="mb-32">
      <h2 class="font-display text-3xl font-bold tracking-tight mb-8">You don't need a video. You need people to understand what you do.</h2>
      <p class="text-body text-lg leading-relaxed mb-6">
        The video is the outcome. Clarity is the goal. From $5,000 — most projects land around $10,000–$15,000.
      </p>
      <a href="mailto:daniel@motionstory.com.au?subject=Motion%20design%20process" class="font-display text-lg font-medium border-b border-black/20 pb-1 hover:border-black transition-colors">
        Email Dan →
      </a>
    </section>
  </div>
</PageLayout>
