---
import PageLayout from '../layouts/PageLayout.astro';

const serviceSchema = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  "name": "Motion design services | Motion Story",
  "description": "Explainer video, product demos, motion graphics, and campaign motion. By industry: startups, SaaS, agencies, and nonprofits.",
  "url": "https://motionstory.com.au/services/",
  "isPartOf": { "@type": "WebSite", "name": "Motion Story", "url": "https://motionstory.com.au" },
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://motionstory.com.au/" },
    { "@type": "ListItem", "position": 2, "name": "Services", "item": "https://motionstory.com.au/services/" },
  ],
};

const byAudience = [
  { href: "/startups/", label: "Startups", blurb: "Launch explainers, waitlists, and the first product story." },
  { href: "/saas-tech/", label: "SaaS & technology", blurb: "Demos, platform explainers, onboarding." },
  { href: "/agencies/", label: "Agencies & studios", blurb: "Senior production — white label or direct." },
  { href: "/causes/", label: "Causes & nonprofits", blurb: "Mission work with clarity, not noise." },
];

const byFormat = [
  { href: "/explainer-videos/", label: "Explainer videos", blurb: "Make the idea land in under two minutes." },
  { href: "/motion-graphics/", label: "Motion graphics", blurb: "Brand, data, UI, and campaign motion." },
  { href: "/saas-explainer-videos/", label: "SaaS explainer videos", blurb: "Software stories for the top of the funnel." },
  { href: "/product-demo-videos/", label: "Product demo videos", blurb: "Walkthroughs that stand in for the first call." },
  { href: "/technology-videos/", label: "Technology videos", blurb: "Platforms and technical buyers — explained clearly." },
];
---

<PageLayout
  title="Motion design services | Motion Story"
  description="Explainer video, product demos, motion graphics, and technology comms. Startups, SaaS, agencies, and nonprofits."
  ctaHeading="Not sure which service fits?"
  ctaLabel="Request a call"
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(serviceSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
  </Fragment>

  <div class="pt-32 pb-24 px-8 max-w-5xl mx-auto">
    <span class="text-metadata mb-6 block">Services</span>
    <h1 class="font-display text-4xl md:text-7xl font-bold tracking-tight leading-[0.9] mb-6">
      What I make,<br class="hidden md:block" /> and who it's for.
    </h1>
    <p class="text-body max-w-lg mb-16">
      Pick the path that matches your brief. Every page leads with the work.
    </p>

    <section class="mb-24 pb-24 border-b border-black/10">
      <span class="text-metadata mb-10 block">By audience</span>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
        {byAudience.map((item) => (
          <a href={item.href} class="group block pb-8 border-b border-black/10">
            <h2 class="font-display text-xl font-bold tracking-tight mb-2 group-hover:opacity-60 transition-opacity">{item.label} →</h2>
            <p class="text-body">{item.blurb}</p>
          </a>
        ))}
      </div>
    </section>

    <section class="mb-24 pb-24 border-b border-black/10">
      <span class="text-metadata mb-10 block">By format</span>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
        {byFormat.map((item) => (
          <a href={item.href} class="group block pb-8 border-b border-black/10">
            <h2 class="font-display text-xl font-bold tracking-tight mb-2 group-hover:opacity-60 transition-opacity">{item.label} →</h2>
            <p class="text-body">{item.blurb}</p>
          </a>
        ))}
      </div>
    </section>

    <p class="text-metadata">
      Work directly with the storyteller throughout your project.{" "}
      <a href="/contact/" class="border-b border-black/20 pb-0.5 hover:border-black transition-colors">Start a project →</a>
    </p>
  </div>
</PageLayout>
