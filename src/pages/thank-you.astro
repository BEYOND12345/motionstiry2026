---
import PageLayout from '../layouts/PageLayout.astro';

const webPageSchema = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  "name": "Message Sent",
  "description": "Thanks for reaching out. I'll get back to you shortly.",
  "url": "https://motionstory.com.au/thank-you/",
  "isPartOf": { "@type": "WebSite", "name": "Motion Story", "url": "https://motionstory.com.au" }
};
---

<PageLayout
  title="Message Sent | Motion Story"
  description="Thanks for reaching out. I'll get back to you shortly."
  showCTA={false}
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(webPageSchema)} />
    <meta name="robots" content="noindex, nofollow" />
  </Fragment>
  <div class="pt-32 pb-24 px-8 max-w-3xl mx-auto text-center">
    <span class="text-metadata mb-8 block">Message Sent</span>
    <h1 class="font-display text-4xl md:text-7xl font-bold tracking-tight leading-[0.9] mb-8">
      Thanks for<br />reaching out.
    </h1>
    <p class="text-body max-w-md mx-auto mb-12">
      I'll read your message and get back to you within a day or two. If it's urgent, email me directly.
    </p>
    <a
      href="mailto:daniel@motionstory.com.au"
      class="font-display text-lg font-bold tracking-tight hover:opacity-50 transition-opacity border-b border-black/20 pb-2"
    >
      daniel@motionstory.com.au
    </a>
  </div>

  <!-- Custom CTA linking to work instead of repeating email -->
  <section class="border-t border-black/10 bg-black/[0.01]">
    <div class="max-w-6xl mx-auto px-8 py-32 text-center">
      <span class="text-metadata mb-8 block">While You're Here</span>
      <h2 class="font-display text-3xl md:text-6xl font-bold tracking-tight mb-12">
        See what I've made.
      </h2>
      <a
        href="/work/"
        class="inline-block px-12 py-5 border border-black hover:bg-black hover:text-white transition-all duration-300 text-metadata"
      >
        See My Work
      </a>
    </div>
  </section>
</PageLayout>
