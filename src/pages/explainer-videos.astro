---
import PageLayout from '../layouts/PageLayout.astro';

const caseStudies = [
  {
    title: "Wipster / Video Feedback Tool",
    description: "Wipster's platform connects creative teams across the entire video review workflow. I built a 90-second product overview that walks through the full experience — no login required, no jargon.",
    link: "/casestudy/wipster-product-overview/",
    vimeoId: "648360270",
  },
  {
    title: "United Nations / Plastic Waste Data",
    description: "The UN needed to turn dense plastic pollution data into something people would actually watch and share. I built a data-driven explainer that made the numbers hit harder than any report could.",
    link: "/casestudy/united-nations/",
    vimeoId: "540393117",
  },
  {
    title: "RSPCA / Saving Cats",
    description: "RSPCA wanted to shift public behaviour around cat ownership. The explainer had to land emotionally without being heavy-handed — clear problem, clear action, sixty seconds.",
    link: "/casestudy/rspca-cat-care-explainer/",
    vimeoId: "762085540",
  },
  {
    title: "Trusyft / Product Promo",
    description: "Trusyft's compliance platform solves a real problem, but explaining it cold was killing conversions. The animated product promo gives prospects the full picture before a single sales call.",
    link: "/casestudy/trusyft-animated-product-promo/",
    vimeoId: "863428533",
  },
];

const services = [
  { title: "SaaS & product explainers", desc: "Turn complex software into a clear, watchable story. Homepage heroes, landing pages, sales decks." },
  { title: "Nonprofit & cause videos", desc: "Make people understand the problem — and feel compelled to act. Campaigns, fundraising, advocacy." },
  { title: "Data visualisation", desc: "Transform numbers and research into motion graphics that actually communicate. Reports, presentations, social." },
  { title: "Campaign & social motion", desc: "Short-form content built for feeds. LinkedIn, Instagram, YouTube pre-roll, paid ads." },
  { title: "Onboarding & training animation", desc: "Get users or staff up to speed faster. Reduce support tickets, improve retention, cut training time." },
];

const serviceSchema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "name": "Explainer Video Production",
  "description": "Animated explainer video production for SaaS, tech, nonprofits, and government. From 60-second overviews to 3-minute deep dives.",
  "provider": {
    "@type": "Organization",
    "name": "Motion Story",
    "url": "https://motionstory.com.au",
  },
  "serviceType": "Explainer Video Production",
  "areaServed": "Worldwide",
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://motionstory.com.au/" },
    { "@type": "ListItem", "position": 2, "name": "Explainer Videos", "item": "https://motionstory.com.au/explainer-videos/" },
  ],
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "What is an explainer video?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "An explainer video is a short animated video — typically 60 seconds to 3 minutes — designed to clearly communicate what a product, service, or idea does and why it matters. They're used on homepages, in sales decks, on social media, and in onboarding flows to replace long-winded copy with something people actually watch.",
      },
    },
    {
      "@type": "Question",
      "name": "How much does an explainer video cost?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Explainer video production typically ranges from $5,000 to $25,000+ depending on length, complexity, and style. A 60-second motion graphics piece sits at a different price point than a 3-minute character-animated narrative. I scope every project individually based on the brief — no cookie-cutter packages.",
      },
    },
    {
      "@type": "Question",
      "name": "How long does it take to produce an explainer video?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Most explainer video projects take 4 to 8 weeks from kickoff to final delivery. That includes scripting, storyboarding, design, animation, and revisions. Tight timelines are possible for simpler projects — I'll always be upfront about what's realistic.",
      },
    },
    {
      "@type": "Question",
      "name": "What's the production process for an explainer video?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "The process runs in three phases: First, we nail the script and storyboard — this is where clarity lives. Second, I design the visual style and key frames. Third, I animate, add sound design, and deliver final files. You get review points at every stage so nothing goes off track.",
      },
    },
    {
      "@type": "Question",
      "name": "What styles of explainer video are available?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "I work across motion graphics, 2D character animation, data visualisation, kinetic typography, and mixed-media styles. The right style depends on your audience and the complexity of your message — not a trend. Every project gets a custom visual direction designed to fit your brand.",
      },
    },
  ],
};
---

<PageLayout
  title="Explainer Videos — Complex Ideas, Simply Explained | Motion Story"
  description="Explainer video production for SaaS, tech, and nonprofits. Motion design that makes people understand — and care. Based in Australia."
  ctaHeading="Got something complex to explain?"
  ctaLabel="Start a Conversation"
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(serviceSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  </Fragment>

  {/* Hero */}
  <div class="pt-32 pb-24 px-8 max-w-5xl mx-auto">
    <span class="text-metadata mb-8 block">Explainer Videos</span>
    <h1 class="font-display text-4xl md:text-8xl font-bold tracking-tight leading-[0.85] mb-8">
      Explainer videos for ideas<br />that don't explain themselves.
    </h1>
    <p class="text-body max-w-xl mb-24">
      Some products, platforms, and missions are genuinely hard to explain. Not because they're bad — because they're complex. An animated explainer video gives you 60 to 180 seconds of pure clarity. No jargon, no filler, no confused faces on the other end of a sales call.
    </p>

    {/* Body */}
    <section class="mb-32 pb-32 border-b border-black/10">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-12">
        <div>
          <span class="text-metadata mb-4 block text-accent">The Brief</span>
        </div>
        <div class="md:col-span-2">
          <p class="text-body text-lg leading-relaxed mb-8">
            A great explainer video does three things: it earns attention in the first five seconds, it makes something complex feel obvious, and it ends with the viewer knowing exactly what to do next. That's it. Clarity, brevity, and visual storytelling — not decoration.
          </p>
          <p class="text-body text-lg leading-relaxed mb-8">
            I've delivered 50+ explainer video projects over 10+ years for SaaS companies, tech startups, nonprofits, and government agencies. Everything from 60-second product overviews to 3-minute deep dives that replace entire pitch decks. The range of work is wide, but the goal is always the same: make people understand, then make them care.
          </p>
          <p class="text-body text-lg leading-relaxed">
            If you're an explainer video company shopping list, here's the difference: I'm a solo operator, not a production line. You work directly with the person designing, animating, and delivering the final piece. No account managers, no handoffs, no diluted feedback loops.
          </p>
        </div>
      </div>
    </section>

    {/* What I Make */}
    <section class="mb-32 pb-32 border-b border-black/10">
      <span class="text-metadata mb-10 block">Explainer Video Services</span>
      <div class="space-y-12">
        {services.map((service, i) => (
          <div class="grid grid-cols-1 md:grid-cols-3 gap-8 pb-12 border-b border-black/10 last:border-b-0 last:pb-0">
            <div>
              <span class="text-metadata mb-4 block text-accent">{(i + 1).toString().padStart(2, '0')}</span>
              <h3 class="font-display text-lg font-medium tracking-tight">{service.title}</h3>
            </div>
            <div class="md:col-span-2">
              <p class="text-body">{service.desc}</p>
            </div>
          </div>
        ))}
      </div>
    </section>

    {/* Case Studies */}
    <section class="mb-32 pb-32 border-b border-black/10">
      <span class="text-metadata mb-10 block">Selected Work</span>
      <h2 class="font-display text-4xl md:text-5xl font-bold tracking-tight leading-[0.9] mb-16">
        Explainer videos,<br />real clients, real results.
      </h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-12">
        {caseStudies.map(study => (
          <a href={study.link} class="group block">
            <div class="aspect-video mb-6 overflow-hidden bg-black/5">
              <img
                src={`https://vumbnail.com/${study.vimeoId}.jpg`}
                alt={study.title}
                class="w-full h-full object-cover group-hover:opacity-80 transition-opacity"
                loading="lazy"
              />
            </div>
            <h3 class="font-display text-xl font-bold tracking-tight mb-3 group-hover:opacity-60 transition-opacity">{study.title}</h3>
            <p class="text-body mb-4">{study.description}</p>
            <span class="text-metadata text-accent group-hover:opacity-60 transition-opacity">View Case Study →</span>
          </a>
        ))}
      </div>
    </section>

    {/* Testimonial */}
    <section class="mb-32 pb-32 border-b border-black/10">
      <span class="text-metadata mb-10 block">Client Feedback</span>
      <blockquote class="text-body text-2xl md:text-3xl leading-relaxed font-display tracking-tight mb-8">
        "40,000 views on YouTube, which increased brand perception and reputation."
      </blockquote>
      <div>
        <p class="font-display font-medium">Simon Lehman</p>
        <p class="text-metadata">Marketing Manager, Acodis</p>
      </div>
    </section>

    {/* FAQ */}
    <section class="mb-32 pb-32 border-b border-black/10">
      <span class="text-metadata mb-10 block">Frequently Asked Questions</span>
      <h2 class="font-display text-4xl md:text-5xl font-bold tracking-tight leading-[0.9] mb-16">
        Common questions about<br />explainer video production.
      </h2>
      <div class="space-y-12">
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8 pb-12 border-b border-black/10">
          <div>
            <h3 class="font-display text-lg font-medium tracking-tight">What is an explainer video?</h3>
          </div>
          <div class="md:col-span-2">
            <p class="text-body">A short animated video — typically 60 seconds to 3 minutes — designed to clearly communicate what a product, service, or idea does and why it matters. They're used on homepages, in sales decks, on social media, and in onboarding flows to replace long-winded copy with something people actually watch.</p>
          </div>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8 pb-12 border-b border-black/10">
          <div>
            <h3 class="font-display text-lg font-medium tracking-tight">How much does an explainer video cost?</h3>
          </div>
          <div class="md:col-span-2">
            <p class="text-body">Explainer video production typically ranges from $5,000 to $25,000+ depending on length, complexity, and style. A 60-second motion graphics piece sits at a different price point than a 3-minute character-animated narrative. I scope every project individually based on the brief — no cookie-cutter packages.</p>
          </div>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8 pb-12 border-b border-black/10">
          <div>
            <h3 class="font-display text-lg font-medium tracking-tight">How long does it take to produce an explainer video?</h3>
          </div>
          <div class="md:col-span-2">
            <p class="text-body">Most projects take 4 to 8 weeks from kickoff to final delivery. That includes scripting, storyboarding, design, animation, and revisions. Tight timelines are possible for simpler projects — I'll always be upfront about what's realistic.</p>
          </div>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8 pb-12 border-b border-black/10">
          <div>
            <h3 class="font-display text-lg font-medium tracking-tight">What's the production process?</h3>
          </div>
          <div class="md:col-span-2">
            <p class="text-body">Three phases. First, we nail the script and storyboard — this is where clarity lives. Second, I design the visual style and key frames. Third, I animate, add sound design, and deliver final files. You get review points at every stage so nothing goes off track.</p>
          </div>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8 pb-12 border-b border-black/10 last:border-b-0 last:pb-0">
          <div>
            <h3 class="font-display text-lg font-medium tracking-tight">What styles of explainer video are available?</h3>
          </div>
          <div class="md:col-span-2">
            <p class="text-body">Motion graphics, 2D character animation, data visualisation, kinetic typography, and mixed-media. The right style depends on your audience and the complexity of your message — not a trend. Every project gets a custom visual direction designed to fit your brand.</p>
          </div>
        </div>
      </div>
    </section>

    {/* Cross-links */}
    <section class="border-t border-black/10 pt-16">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <a href="/saas-tech/" class="group p-8 border border-black/10 hover:border-black/20 transition-colors">
          <span class="text-metadata mb-3 block">SaaS & Tech</span>
          <p class="font-display text-lg font-medium group-hover:opacity-60 transition-opacity">Product videos for software →</p>
          <p class="text-body !text-sm mt-2">Demos, onboarding, platform explainers.</p>
        </a>
        <a href="/causes/" class="group p-8 border border-black/10 hover:border-black/20 transition-colors">
          <span class="text-metadata mb-3 block">Causes & Nonprofits</span>
          <p class="font-display text-lg font-medium group-hover:opacity-60 transition-opacity">Motion for missions that matter →</p>
          <p class="text-body !text-sm mt-2">Campaigns, advocacy, fundraising.</p>
        </a>
        <a href="/contact/" class="group p-8 border border-black/10 hover:border-black/20 transition-colors">
          <span class="text-metadata mb-3 block">Start a Project</span>
          <p class="font-display text-lg font-medium group-hover:opacity-60 transition-opacity">Get in touch →</p>
          <p class="text-body !text-sm mt-2">Tell me what you're working on.</p>
        </a>
      </div>
    </section>
  </div>
</PageLayout>
