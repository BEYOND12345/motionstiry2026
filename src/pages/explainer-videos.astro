---
import PageLayout from '../layouts/PageLayout.astro';
import ServiceLanding from '../components/ServiceLanding.astro';

const work = [
  { title: "Mosaic / Strategic Data Planning", link: "/casestudy/mosaic-platform-explained/", vimeoId: "879242129" },
  { title: "Atomic / In-App Messaging", link: "/casestudy/atomic-in-app-messaging/", vimeoId: "861022443" },
  { title: "Acodis / AI Document Processing", link: "/casestudy/acodis/", vimeoId: "580088673" },
  { title: "Giraffe / Designing Cities", link: "/casestudy/giraffe/", vimeoId: "762112642" },
  { title: "Wipster / Video Feedback Tool", link: "/casestudy/wipster-product-overview/", vimeoId: "648360270" },
  { title: "Bat Nav / Big Battery Power", link: "/casestudy/bat-nav-platform-explainer/", vimeoId: "479992275" },
];

const moreWork = [
  { title: "Ranalytic / RF Scanner", link: "/casestudy/ranalytic-rf-scanner/", vimeoId: "759713697" },
  { title: "United Nations / Plastic Waste Data", link: "/casestudy/united-nations/", vimeoId: "540393117" },
  { title: "Trudi / AI Property Management", link: "/casestudy/property-management-explainer-video/", vimeoId: "866174146" },
  { title: "Shape Connect / Website Security", link: "/casestudy/shape-connect/", vimeoId: "320632556" },
];

const serviceSchema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "name": "Explainer Video Production",
  "description": "Animated explainer video production for SaaS, tech, nonprofits, and government. From 60-second overviews to 3-minute deep dives.",
  "provider": { "@type": "Organization", "name": "Motion Story", "url": "https://motionstory.com.au" },
  "serviceType": "Explainer Video Production",
  "areaServed": "Worldwide",
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://motionstory.com.au/" },
    { "@type": "ListItem", "position": 2, "name": "Explainer Videos", "item": "https://motionstory.com.au/explainer-videos/" },
  ],
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    { "@type": "Question", "name": "How much does an explainer video cost?", "acceptedAnswer": { "@type": "Answer", "text": "Explainer video production typically ranges from $5,000 to $25,000+ depending on length, complexity, and style. Every project is scoped individually — no cookie-cutter packages." } },
    { "@type": "Question", "name": "How long does it take to produce an explainer video?", "acceptedAnswer": { "@type": "Answer", "text": "Most projects take 4 to 8 weeks from kickoff to final delivery, including scripting, storyboarding, design, animation, and revisions." } },
    { "@type": "Question", "name": "What's the difference working with Motion Story?", "acceptedAnswer": { "@type": "Answer", "text": "You work directly with Dan — the person writing, designing, and animating your explainer — throughout the project. No account managers, no handoffs." } },
  ],
};
---

<PageLayout
  title="Explainer Video Production | Motion Story"
  description="Explainer video production for SaaS, tech, and nonprofits. Motion design that makes people understand and care. Based in Australia."
  ctaHeading="Got something complex to explain?"
  ctaLabel="Start a Conversation"
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(serviceSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  </Fragment>

  <ServiceLanding
    eyebrow="Explainer Videos"
    headline={["Explainers for ideas", "that don't explain themselves."]}
    lede="Complex products, platforms, and missions — made clear in 60 to 180 seconds."
    answer="Animated explainer video production for SaaS, tech, nonprofits, and government. You work directly with Dan — script, design, and animation — from brief to final film."
    work={work}
    moreWork={moreWork}
    quote="What would normally take hours to explain now takes 90 seconds."
    quoteBy="AMSED"
    faqs={[
      { label: "Cost", body: "Typically $5,000–$25,000+ depending on length and complexity. Fixed quote per project." },
      { label: "Timeline", body: "Most explainers take 4–8 weeks from kickoff to final delivery." },
      { label: "How we work", body: "You work directly with Dan — script, design, and animation. No account managers, no handoffs." },
    ]}
    links={[
      { href: "/technology-videos/", eyebrow: "Tech", label: "Technology videos →" },
      { href: "/saas-explainer-videos/", eyebrow: "SaaS", label: "SaaS explainer videos →" },
      { href: "/contact/", eyebrow: "Next", label: "Start a project →" },
    ]}
  />
</PageLayout>
