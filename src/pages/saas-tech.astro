---
import PageLayout from '../layouts/PageLayout.astro';

const caseStudies = [
  {
    title: "Atomic / In-App Messaging",
    description: "Atomic's product was technically deep and hard to pitch to non-technical buyers. I built a 60-second motion piece that did the explaining before the sales call started.",
    link: "/casestudy/atomic-in-app-messaging/",
    vimeoId: "861022443",
  },
  {
    title: "Wipster / Video Feedback Tool",
    description: "Wipster needed to show how their video review workflow connected across teams. The product overview walks through the full platform, step by step, in 90 seconds.",
    link: "/casestudy/wipster-product-overview/",
    vimeoId: "648360270",
  },
  {
    title: "Mosaic / Strategic Data Planning",
    description: "Mosaic's platform is built for finance teams managing complex planning workflows. I distilled that into a clear platform piece that works on a landing page and in a sales deck.",
    link: "/casestudy/mosaic-platform-explained/",
    vimeoId: "879242129",
  },
  {
    title: "Trudi / AI Property Management",
    description: "Trudi's AI handles tenant communication, maintenance, and financials. The product demo walks through each workflow without overwhelming the viewer.",
    link: "/casestudy/property-management-explainer-video/",
    vimeoId: "866174146",
  },
];

const services = [
  { title: "Product demo videos", desc: "Show the software in action, step by step." },
  { title: "Platform explainers", desc: "What it does, how it works, why it matters." },
  { title: "Onboarding animations", desc: "Get users to value faster, reduce churn." },
  { title: "Pitch deck animations", desc: "Investor and board-level presentations." },
  { title: "Social and paid motion", desc: "Short-form for LinkedIn, paid ads, pre-roll." },
];

const serviceSchema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "name": "Motion Design for SaaS & Tech Companies",
  "description": "Product demo videos, platform explainers, and onboarding animation for SaaS and tech companies.",
  "provider": {
    "@type": "Organization",
    "name": "Motion Story",
    "url": "https://motionstory.com.au",
  },
  "serviceType": "Motion Design for SaaS",
  "areaServed": "Worldwide",
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://motionstory.com.au/" },
    { "@type": "ListItem", "position": 2, "name": "SaaS & Tech", "item": "https://motionstory.com.au/saas-tech/" },
  ],
};

const faqs = [
  {
    q: "What kind of motion design do SaaS companies need most?",
    a: "It depends on the stage and the problem. Early-stage SaaS usually needs a homepage-hero explainer — 60 to 90 seconds that answers 'what does this do and why should I care?' before a prospect clicks away. Mid-stage companies need product demo videos for sales and onboarding animations to reduce churn. Late-stage and enterprise usually need platform explainers and investor-facing pitch motion. I scope the piece to the sales stage it needs to serve.",
  },
  {
    q: "How is a SaaS product demo different from a regular explainer video?",
    a: "A product demo shows the software working. Actual UI, real workflows, step-by-step. The goal is to replace the first 10 minutes of a sales call. A general explainer is higher-level — it explains the category and the value proposition without necessarily showing the interface. Most SaaS companies need both, at different stages of the funnel.",
  },
  {
    q: "Do you work with pre-launch or early-stage SaaS companies?",
    a: "Yes. I've made videos for companies at seed stage, Series A, and well beyond. Pre-launch clients often benefit most — a clear motion piece becomes the single best tool for investor updates, waitlist pages, and cold outreach. It's also the fastest way to test whether your product messaging actually lands.",
  },
  {
    q: "How much does a SaaS product video cost?",
    a: "Most SaaS projects fall between $8,000 and $25,000. A 60-second homepage hero is at the lower end. A full platform explainer with multiple workflows, or a series of feature videos for onboarding, sits at the higher end. I scope every project against the specific brief rather than selling packages.",
  },
  {
    q: "Can you use our existing brand system and UI?",
    a: "Yes — and usually the best result comes from doing exactly that. Matching your actual product interface, brand colours, and typography means the video feels native to your site and onboarding. When there's room, I'll also introduce visual devices and motion principles that extend the brand rather than just replicating screenshots.",
  },
];

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqs.map((f) => ({
    "@type": "Question",
    "name": f.q,
    "acceptedAnswer": { "@type": "Answer", "text": f.a },
  })),
};
---

<PageLayout
  title="Motion Design for SaaS & Tech Companies | Motion Story"
  description="Product demo videos, platform explainers, and onboarding animation for SaaS and tech companies. Dan Neale, Motion Story."
  ctaHeading="Got a product that's hard to explain?"
  ctaLabel="Start a Conversation"
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(serviceSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  </Fragment>

  {/* Hero */}
  <div class="pt-32 pb-24 px-8 max-w-5xl mx-auto">
    <span class="text-metadata mb-8 block">SaaS & Tech</span>
    <h1 class="font-display text-4xl md:text-8xl font-bold tracking-tight leading-[0.85] mb-8">
      Your product is brilliant.<br />Your demo isn't explaining it.
    </h1>
    <p class="text-body max-w-xl mb-24">
      SaaS is a hard sell because the product is invisible. You can't hold it. You can't demo it without a login. And by the time someone gets to a sales call, half the room has already decided it's too complicated.
    </p>

    {/* Body */}
    <section class="mb-32 pb-32 border-b border-black/10">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-12 items-start">
        <div>
          <span class="text-metadata mb-4 block text-accent">The Brief</span>
        </div>
        <div class="md:col-span-2">
          <p class="text-body text-lg leading-relaxed mb-8">
            A well-made motion design piece changes that before the sales call even happens. Your homepage does the heavy lifting. Your onboarding doesn't lose people in the first week. Your pipeline gets shorter because prospects show up to calls already understanding what they're buying.
          </p>
          <p class="text-body text-lg leading-relaxed">
            I've made product videos for platforms from seed stage to Series B. Software with three stakeholder audiences, dashboards only power users understand, features that only make sense in context. That's the brief I'm built for.
          </p>
        </div>
      </div>
    </section>

    {/* What I Make */}
    <section class="mb-32 pb-32 border-b border-black/10">
      <span class="text-metadata mb-10 block">What I Make</span>
      <div class="space-y-12">
        {services.map((service, i) => (
          <div class="grid grid-cols-1 md:grid-cols-3 gap-8 items-start pb-12 border-b border-black/10 last:border-b-0 last:pb-0">
            <div>
              <span class="text-metadata mb-4 block text-accent">{(i + 1).toString().padStart(2, '0')}</span>
              <h3 class="font-display text-lg font-medium tracking-tight">{service.title}</h3>
            </div>
            <div class="md:col-span-2">
              <p class="text-body">{service.desc}</p>
            </div>
          </div>
        ))}
      </div>
    </section>

    {/* Case Studies */}
    <section class="mb-32 pb-32 border-b border-black/10">
      <span class="text-metadata mb-10 block">Selected Work</span>
      <h2 class="font-display text-4xl md:text-5xl font-bold tracking-tight leading-[0.9] mb-16">
        SaaS projects,<br />real results.
      </h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-12">
        {caseStudies.map(study => (
          <a href={study.link} class="group block">
            <div class="aspect-video mb-6 overflow-hidden bg-black/5">
              <img
                src={`https://vumbnail.com/${study.vimeoId}.jpg`}
                alt={study.title}
                class="w-full h-full object-cover group-hover:opacity-80 transition-opacity"
                loading="lazy"
              />
            </div>
            <h3 class="font-display text-xl font-bold tracking-tight mb-3 group-hover:opacity-60 transition-opacity">{study.title}</h3>
            <p class="text-body mb-4">{study.description}</p>
            <span class="text-metadata text-accent group-hover:opacity-60 transition-opacity">View Case Study →</span>
          </a>
        ))}
      </div>
    </section>

    {/* Testimonial */}
    <section class="mb-32 pb-32 border-b border-black/10">
      <span class="text-metadata mb-10 block">Client Feedback</span>
      <blockquote class="text-body text-2xl md:text-3xl leading-relaxed font-display tracking-tight mb-8">
        "40,000 views on YouTube, which increased brand perception and reputation."
      </blockquote>
      <div>
        <p class="font-display font-medium">Simon Lehman</p>
        <p class="text-metadata">Marketing Manager, Acodis</p>
      </div>
    </section>

    {/* FAQ */}
    <section class="mb-32 pb-32 border-b border-black/10">
      <span class="text-metadata mb-10 block">Frequently Asked Questions</span>
      <h2 class="font-display text-4xl md:text-5xl font-bold tracking-tight leading-[0.9] mb-16">
        Common questions<br />about SaaS video.
      </h2>
      <div class="space-y-12">
        {faqs.map((faq) => (
          <div class="grid grid-cols-1 md:grid-cols-3 gap-8 items-start pb-12 border-b border-black/10 last:border-b-0 last:pb-0">
            <div>
              <h3 class="font-display text-lg font-medium tracking-tight">{faq.q}</h3>
            </div>
            <div class="md:col-span-2">
              <p class="text-body">{faq.a}</p>
            </div>
          </div>
        ))}
      </div>
    </section>

    {/* Cross-links */}
    <section class="border-t border-black/10 pt-16">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <a href="/process/" class="group p-8 border border-black/10 hover:border-black/20 transition-colors">
          <span class="text-metadata mb-3 block">Process</span>
          <p class="font-display text-lg font-medium group-hover:opacity-60 transition-opacity">How I work →</p>
          <p class="text-body !text-sm mt-2">Three phases. No wasted time.</p>
        </a>
        <a href="/work/" class="group p-8 border border-black/10 hover:border-black/20 transition-colors">
          <span class="text-metadata mb-3 block">Work</span>
          <p class="font-display text-lg font-medium group-hover:opacity-60 transition-opacity">See all work →</p>
          <p class="text-body !text-sm mt-2">50+ projects delivered worldwide</p>
        </a>
        <a href="/contact/" class="group p-8 border border-black/10 hover:border-black/20 transition-colors">
          <span class="text-metadata mb-3 block">Start a Project</span>
          <p class="font-display text-lg font-medium group-hover:opacity-60 transition-opacity">Get in touch →</p>
          <p class="text-body !text-sm mt-2">Tell me what you're working on</p>
        </a>
      </div>
    </section>
  </div>
</PageLayout>
