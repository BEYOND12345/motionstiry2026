---
import PageLayout from '../layouts/PageLayout.astro';
import ServiceLanding from '../components/ServiceLanding.astro';

const work = [
  { title: "Atomic / In-App Messaging", link: "/casestudy/atomic-in-app-messaging/", vimeoId: "861022443" },
  { title: "Mosaic / Strategic Data Planning", link: "/casestudy/mosaic-platform-explained/", vimeoId: "879242129" },
  { title: "Wipster / Video Feedback Tool", link: "/casestudy/wipster-product-overview/", vimeoId: "648360270" },
  { title: "Trudi / AI Property Management", link: "/casestudy/property-management-explainer-video/", vimeoId: "866174146" },
  { title: "Acodis / AI Document Processing", link: "/casestudy/acodis/", vimeoId: "580088673" },
  { title: "Good2Pay / Paperless Invoicing", link: "/casestudy/good2pay/", vimeoId: "448704979" },
];

const moreWork = [
  { title: "InfoView / Digital Expense Management", link: "/casestudy/infoview/", vimeoId: "404852749" },
  { title: "Giraffe / Designing Cities", link: "/casestudy/giraffe/", vimeoId: "762112642" },
  { title: "Class Trust / Accounting Software", link: "/casestudy/class-trust-motion-graphic-explainer/", vimeoId: "485803845" },
  { title: "Hey You / Food Ordering App", link: "/casestudy/heyyou-app/", vimeoId: "351936883" },
];

const serviceSchema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "name": "Motion Design for SaaS & Tech Companies",
  "description": "Product demo videos, platform explainers, and onboarding animation for SaaS and tech companies.",
  "provider": { "@type": "Organization", "name": "Motion Story", "url": "https://motionstory.com.au" },
  "serviceType": "Motion Design for SaaS",
  "areaServed": "Worldwide",
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://motionstory.com.au/" },
    { "@type": "ListItem", "position": 2, "name": "SaaS & Tech", "item": "https://motionstory.com.au/saas-tech/" },
  ],
};
---

<PageLayout
  title="Motion Design for SaaS & Tech | Motion Story"
  description="Product demos, platform explainers, and onboarding animation for SaaS and tech. Work directly with Dan."
  ctaHeading="Got a product that's hard to explain?"
  ctaLabel="Start a Conversation"
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(serviceSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
  </Fragment>

  <ServiceLanding
    eyebrow="SaaS & Tech"
    headline={["Your product is brilliant.", "Your demo isn't explaining it."]}
    lede="Product demos, platform explainers, and onboarding motion for software that needs to be understood fast."
    answer="Motion design for SaaS and tech companies — product demos, platform explainers, and onboarding animation. Direct with Dan, no handoffs."
    work={work}
    moreWork={moreWork}
    quote="40,000 views on YouTube, which increased brand perception and reputation."
    quoteBy="Simon Lehman"
    quoteRole="Marketing Manager, Acodis"
    faqs={[
      { label: "What I make", body: "Product demos, platform explainers, onboarding animation, pitch pieces, and short-form for LinkedIn and paid." },
      { label: "How we work", body: "You work directly with Dan — script, design, and animation. No account managers, no handoffs." },
    ]}
    links={[
      { href: "/saas-explainer-videos/", eyebrow: "SaaS", label: "SaaS explainer videos →" },
      { href: "/product-demo-videos/", eyebrow: "Demos", label: "Product demo videos →" },
      { href: "/contact/", eyebrow: "Next", label: "Start a project →" },
    ]}
  />
</PageLayout>
