---
import PageLayout from '../layouts/PageLayout.astro';
import ServiceLanding from '../components/ServiceLanding.astro';

const work = [
  { title: "Meltwater / Brand Story", link: "/casestudy/meltwater/", vimeoId: "394326130" },
  { title: "United Nations / Plastic Waste Data", link: "/casestudy/united-nations/", vimeoId: "540393117" },
  { title: "Giraffe / Designing Cities", link: "/casestudy/giraffe/", vimeoId: "762112642" },
  { title: "Acodis / AI Document Processing", link: "/casestudy/acodis/", vimeoId: "580088673" },
  { title: "Method / Beautiful Bin System", link: "/casestudy/method-explainer-video/", vimeoId: "557884851" },
  { title: "Wipster / Video Feedback Tool", link: "/casestudy/wipster-product-overview/", vimeoId: "648360270" },
];

const moreWork = [
  { title: "RSPCA / Saving Cats", link: "/casestudy/rspca-cat-care-explainer/", vimeoId: "762085540" },
  { title: "Bat Nav / Big Battery Power", link: "/casestudy/bat-nav-platform-explainer/", vimeoId: "479992275" },
  { title: "Braums / Touchless Road Crossing", link: "/casestudy/braums/", vimeoId: "458000764" },
  { title: "Atomic / In-App Messaging", link: "/casestudy/atomic-in-app-messaging/", vimeoId: "861022443" },
];

const serviceSchema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "name": "Motion Graphics Studio",
  "description": "Motion graphics studio for complex ideas. Explainers, product demos, brand animation, data visualisation, and campaign motion.",
  "provider": { "@type": "Organization", "name": "Motion Story", "url": "https://motionstory.com.au" },
  "serviceType": "Motion Graphics Production",
  "areaServed": "Worldwide",
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://motionstory.com.au/" },
    { "@type": "ListItem", "position": 2, "name": "Motion Graphics", "item": "https://motionstory.com.au/motion-graphics/" },
  ],
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    { "@type": "Question", "name": "How much does motion graphics production cost?", "acceptedAnswer": { "@type": "Answer", "text": "From $5,000. Most projects land around $10,000–$15,000. Fixed quote upfront." } },
    { "@type": "Question", "name": "What's the difference working with Motion Story?", "acceptedAnswer": { "@type": "Answer", "text": "You work with Dan throughout — concept, storyboard, design, illustration, and animation. No account managers, no handoffs. Agencies welcome, white label or direct." } },
  ],
};
---

<PageLayout
  showCTA={false}
  title="Motion Graphics Studio | Motion Story"
  description="Motion graphics for complex ideas. Explainers, product demos, brand animation, and campaign motion. Work directly with Dan."
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(serviceSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  </Fragment>

  <ServiceLanding
    eyebrow="Motion Graphics Studio"
    headline={["Motion graphics for", "complex ideas."]}
    lede="A focused motion practice for products, brands, and campaigns that need clarity."
    emailSubject="Motion graphics"
    work={work}
    moreWork={moreWork}
    quote="40,000 views on YouTube, which increased brand perception and reputation."
    quoteBy="Simon Lehman"
    quoteRole="Marketing Manager, Acodis"
    faqs={[
      { label: "Cost", body: "From $5,000. Most projects land around $10,000–$15,000. Fixed quote upfront." },
      { label: "How we work", body: "You work with Dan throughout — concept, storyboard, design, illustration, and animation. Agencies welcome, white label or direct." },
    ]}
    links={[
      { href: "/explainer-videos/", eyebrow: "Explainers", label: "Explainer videos →" },
      { href: "/saas-explainer-videos/", eyebrow: "SaaS", label: "SaaS explainer videos →" },
      { href: "/work/", eyebrow: "Work", label: "See all work →" },
    ]}
  />
</PageLayout>
