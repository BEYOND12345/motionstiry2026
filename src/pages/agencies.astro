---
import PageLayout from '../layouts/PageLayout.astro';
import ServiceLanding from '../components/ServiceLanding.astro';

const work = [
  { title: "Wipster / Video Feedback Tool", link: "/casestudy/wipster-product-overview/", vimeoId: "648360270" },
  { title: "Meltwater / Brand Story", link: "/casestudy/meltwater/", vimeoId: "394326130" },
  { title: "Atomic / In-App Messaging", link: "/casestudy/atomic-in-app-messaging/", vimeoId: "861022443" },
  { title: "United Nations / Plastic Waste Data", link: "/casestudy/united-nations/", vimeoId: "540393117" },
  { title: "Mosaic / Strategic Data Planning", link: "/casestudy/mosaic-platform-explained/", vimeoId: "879242129" },
  { title: "Acodis / AI Document Processing", link: "/casestudy/acodis/", vimeoId: "580088673" },
];

const moreWork = [
  { title: "Giraffe / Designing Cities", link: "/casestudy/giraffe/", vimeoId: "762112642" },
  { title: "Method / Beautiful Bin System", link: "/casestudy/method-explainer-video/", vimeoId: "557884851" },
  { title: "Trudi / AI Property Management", link: "/casestudy/property-management-explainer-video/", vimeoId: "866174146" },
  { title: "Good2Pay / Paperless Invoicing", link: "/casestudy/good2pay/", vimeoId: "448704979" },
];

const serviceSchema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "name": "Motion Design for Agencies & Studios",
  "description": "Senior motion design production for branding agencies, design studios, and integrated creative shops. White label or direct.",
  "provider": { "@type": "Organization", "name": "Motion Story", "url": "https://motionstory.com.au" },
  "serviceType": "Motion Design Production for Agencies",
  "areaServed": "Worldwide",
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://motionstory.com.au/" },
    { "@type": "ListItem", "position": 2, "name": "Agencies & Studios", "item": "https://motionstory.com.au/agencies/" },
  ],
};
---

<PageLayout
  showCTA={false}
  floatSubject="Agency motion production"
  title="Motion Design for Agencies & Studios | Motion Story"
  description="Senior motion design for agencies and studios. White label or direct. Work directly with Dan."
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(serviceSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
  </Fragment>

  <ServiceLanding
    eyebrow="Agencies & Studios"
    headline={["Your client needs motion.", "You need bandwidth."]}
    lede="Senior animation production for agencies: white label or direct. Your relationship. My craft."
    work={work}
    moreWork={moreWork}
    faqs={[
      { label: "Cost", body: "From $5,000. Most projects land around $10,000–$15,000. Fixed quote upfront." },
      { label: "White label", body: "You brief me. I deliver finished files under your agency name." },
      { label: "Direct with client", body: "Bring me in as the motion specialist alongside your team." },
    ]}
    links={[
      { href: "/work/", eyebrow: "Work", label: "See all work →" },
      { href: "/process/", eyebrow: "Process", label: "How I work →" },
      { href: "/explainer-videos/", eyebrow: "Explainers", label: "Explainer videos →" },
    ]}
  />
</PageLayout>
