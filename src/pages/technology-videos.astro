---
import PageLayout from '../layouts/PageLayout.astro';
import ServiceLanding from '../components/ServiceLanding.astro';

const work = [
  { title: "Mosaic / Strategic Data Planning", link: "/casestudy/mosaic-platform-explained/", vimeoId: "879242129" },
  { title: "Acodis / AI Document Processing", link: "/casestudy/acodis/", vimeoId: "580088673" },
  { title: "Atomic / In-App Messaging", link: "/casestudy/atomic-in-app-messaging/", vimeoId: "861022443" },
  { title: "Giraffe / Designing Cities", link: "/casestudy/giraffe/", vimeoId: "762112642" },
  { title: "Wipster / Video Feedback Tool", link: "/casestudy/wipster-product-overview/", vimeoId: "648360270" },
  { title: "Bat Nav / Big Battery Power", link: "/casestudy/bat-nav-platform-explainer/", vimeoId: "479992275" },
];

const moreWork = [
  { title: "Ranalytic / RF Scanner", link: "/casestudy/ranalytic-rf-scanner/", vimeoId: "759713697" },
  { title: "Shape Connect / Website Security", link: "/casestudy/shape-connect/", vimeoId: "320632556" },
  { title: "InfoView / Digital Expense Management", link: "/casestudy/infoview/", vimeoId: "404852749" },
  { title: "Senate Matching / Data Matching", link: "/casestudy/senate-matching/", vimeoId: "301736476" },
  { title: "READ / Medical Journals", link: "/casestudy/read-accessing-medical-journals/", vimeoId: "245112003" },
  { title: "Class Trust / Accounting Software", link: "/casestudy/class-trust-motion-graphic-explainer/", vimeoId: "485803845" },
];

const serviceSchema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "name": "Technology Videos",
  "description": "Technology explainer videos that make technical products understandable for buyers, users, and stakeholders.",
  "provider": { "@type": "Organization", "name": "Motion Story", "url": "https://motionstory.com.au" },
  "serviceType": "Technology Video Production",
  "areaServed": "Worldwide",
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://motionstory.com.au/" },
    { "@type": "ListItem", "position": 2, "name": "Technology Videos", "item": "https://motionstory.com.au/technology-videos/" },
  ],
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    { "@type": "Question", "name": "What are technology videos?", "acceptedAnswer": { "@type": "Answer", "text": "Technology videos make technical products understandable for buyers, users, and stakeholders — combining product context, interface storytelling, and clear motion design." } },
    { "@type": "Question", "name": "What's the difference working with Motion Story?", "acceptedAnswer": { "@type": "Answer", "text": "You work directly with Dan — the person writing, designing, and animating — throughout the project. No account managers, no handoffs." } },
  ],
};
---

<PageLayout
  showCTA={false}
  title="Technology Videos | Motion Story"
  description="Technology explainer videos for SaaS, platforms, and deep-tech. Clear stories for complex products. Work directly with Dan."
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(serviceSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  </Fragment>

  <ServiceLanding
    eyebrow="Technology Videos"
    headline={["Complex technology.", "Clear story."]}
    lede="Technology videos that make platforms and deep products understandable, without dumbing them down."
    emailSubject="Technology video"
    work={work}
    moreWork={moreWork}
    quote="40,000 views on YouTube, which increased brand perception and reputation."
    quoteBy="Simon Lehman"
    quoteRole="Marketing Manager, Acodis"
    faqs={[
      { label: "Cost", body: "From $5,000. Most projects land around $10,000–$15,000. Fixed quote upfront." },
      { label: "Who it's for", body: "SaaS, platforms, deep-tech, and B2B products that need buyers and stakeholders to get it fast." },
      { label: "How we work", body: "You work with Dan throughout — concept, storyboard, design, illustration, and animation. Agencies welcome, white label or direct." },
    ]}
    links={[
      { href: "/product-demo-videos/", eyebrow: "Demos", label: "Product demo videos →" },
      { href: "/saas-explainer-videos/", eyebrow: "SaaS", label: "SaaS explainer videos →" },
      { href: "/work/", eyebrow: "Work", label: "See all work →" },
    ]}
  />
</PageLayout>
