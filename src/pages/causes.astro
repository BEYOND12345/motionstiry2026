---
import PageLayout from '../layouts/PageLayout.astro';
import ServiceLanding from '../components/ServiceLanding.astro';

const work = [
  { title: "RSPCA / Cat Care Programme", link: "/casestudy/rspca-cat-care-explainer/", vimeoId: "762085540" },
  { title: "United Nations / Plastic Waste Data", link: "/casestudy/united-nations/", vimeoId: "540393117" },
  { title: "Red Cross / Covid Vaccine Explainer", link: "/casestudy/redcross-covid-vacine-explainer/", vimeoId: "762086291" },
  { title: "RSPCA / Workplace Giving", link: "/casestudy/rspca-work-place-giving/", vimeoId: "792094663" },
  { title: "ACIR / Food Waste Programme", link: "/casestudy/acir/", vimeoId: "557016672" },
  { title: "NSW Gov / Pinch Point Explained", link: "/casestudy/nsw-gov-pinch-point-explainer/", vimeoId: "306054358" },
];

const moreWork = [
  { title: "Solar My School", link: "/casestudy/solar-my-school/", vimeoId: "401121460" },
  { title: "IPA / Electric Car Road Tax", link: "/casestudy/ipa-australia/", vimeoId: "441916573" },
  { title: "NeatStreets / Report Hazards", link: "/casestudy/neat-streets-app/", vimeoId: "244918295" },
  { title: "Method / Beautiful Bin System", link: "/casestudy/method-explainer-video/", vimeoId: "557884851" },
];

const serviceSchema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "name": "Motion Design for Charities & Nonprofits",
  "description": "Motion design for causes, charities, nonprofits, and government organisations.",
  "provider": { "@type": "Organization", "name": "Motion Story", "url": "https://motionstory.com.au" },
  "serviceType": "Motion Design for Nonprofits and Government",
  "areaServed": "Worldwide",
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://motionstory.com.au/" },
    { "@type": "ListItem", "position": 2, "name": "Causes & Nonprofits", "item": "https://motionstory.com.au/causes/" },
  ],
};
---

<PageLayout
  showCTA={false}
  floatSubject="Nonprofit motion design"
  title="Motion Design for Charities & Nonprofits | Motion Story"
  description="Motion design for causes, charities, nonprofits, and government. Complex missions made immediately clear."
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(serviceSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
  </Fragment>

  <ServiceLanding
    eyebrow="Causes & Nonprofits"
    headline={["Important work deserves", "to be understood."]}
    lede="Motion for charities, nonprofits, and government: clarity without noise."
    work={work}
    moreWork={moreWork}
    faqs={[
      { label: "Cost", body: "From $5,000. Most projects land around $10,000–$15,000. Fixed quote upfront." },
      { label: "The stakes", body: "A confusing message doesn't just lose attention — it loses donors, volunteers, and the people the programme is meant to help." },
      { label: "How we work", body: "You work with Dan throughout — concept, storyboard, design, illustration, and animation. Agencies welcome, white label or direct." },
    ]}
    links={[
      { href: "/explainer-videos/", eyebrow: "Explainers", label: "Explainer videos →" },
      { href: "/work/", eyebrow: "Work", label: "See all work →" },
      { href: "/process/", eyebrow: "Process", label: "How I work →" },
    ]}
  />
</PageLayout>
