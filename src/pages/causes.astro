---
import PageLayout from '../layouts/PageLayout.astro';

const caseStudies = [
  {
    title: "RSPCA / Cat Care Programme",
    description: "An animation for RSPCA's cat welfare programme that balances emotion with practical information — getting the message across without manipulation.",
    link: "/casestudy/rspca-cat-care-explainer/",
    vimeoId: "762085540",
  },
  {
    title: "RSPCA / Workplace Giving",
    description: "A motion piece for RSPCA's workplace giving programme. The brief was to drive corporate sign-ups by making the impact of regular contributions immediately clear.",
    link: "/casestudy/rspca-work-place-giving/",
    vimeoId: "792094663",
  },
  {
    title: "United Nations / Plastic Waste Data",
    description: "A data-driven animation for the United Nations that transforms global plastic waste statistics into a visual narrative designed for international policy discussions.",
    link: "/casestudy/united-nations/",
    vimeoId: "540393117",
  },
  {
    title: "ACIR / Food Waste Programme",
    description: "An animation for ACIR's food waste reduction programme. Complex supply chain data turned into a clear visual argument for action.",
    link: "/casestudy/acir/",
    vimeoId: "557016672",
  },
];

const serviceSchema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "name": "Motion Design for Charities & Nonprofits",
  "description": "Motion design for causes, charities, nonprofits, and government organisations. Complex missions made immediately clear.",
  "provider": {
    "@type": "Organization",
    "name": "Motion Story",
    "url": "https://motionstory.com.au",
  },
  "serviceType": "Motion Design for Nonprofits and Government",
  "areaServed": "Worldwide",
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://motionstory.com.au/" },
    { "@type": "ListItem", "position": 2, "name": "Causes & Nonprofits", "item": "https://motionstory.com.au/causes/" },
  ],
};
---

<PageLayout
  title="Motion Design for Charities & Nonprofits | Motion Story"
  description="Motion design for causes, charities, nonprofits, and government organisations. Complex missions made immediately clear. Dan Neale, Motion Story."
  ctaHeading="Got a mission that's hard to communicate?"
  ctaLabel="Talk About Your Project"
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(serviceSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
  </Fragment>

  {/* Hero */}
  <div class="pt-32 pb-24 px-8 max-w-5xl mx-auto">
    <span class="text-metadata mb-8 block">Causes & Nonprofits</span>
    <h1 class="font-display text-4xl md:text-8xl font-bold tracking-tight leading-[0.85] mb-8">
      Important work deserves<br />to be understood.
    </h1>
    <p class="text-body max-w-xl mb-24">
      Charities, nonprofits, and government organisations often have the most complex stories to tell — and the smallest tolerance for something that doesn't land.
    </p>

    {/* Body */}
    <section class="mb-32 pb-32 border-b border-black/10">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-12">
        <div>
          <span class="text-metadata mb-4 block text-accent">The Work</span>
        </div>
        <div class="md:col-span-2">
          <p class="text-body text-lg leading-relaxed mb-8">
            A confusing message doesn't just lose attention. For a cause, it loses donors. It loses volunteers. It loses the people whose lives depend on the program working.
          </p>
          <p class="text-body text-lg leading-relaxed mb-8">
            I've made work for the RSPCA, the United Nations, and government data programs — projects where the stakes are real and the brief needed to cut through noise, not add to it.
          </p>
          <p class="text-body text-lg leading-relaxed mb-8">
            The approach is the same as any other brief: find the one thing that matters, build the motion design around that, and strip everything else out.
          </p>
          <p class="text-body text-lg leading-relaxed">
            Your cause is hard to explain because it's complicated. That's not a limitation — that's exactly the brief I'm built for.
          </p>
        </div>
      </div>
    </section>

    {/* Case Studies */}
    <section class="mb-32 pb-32 border-b border-black/10">
      <span class="text-metadata mb-10 block">Selected Work</span>
      <h2 class="font-display text-4xl md:text-5xl font-bold tracking-tight leading-[0.9] mb-16">
        Causes I've<br />worked on.
      </h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-12">
        {caseStudies.map(study => (
          <a href={study.link} class="group block">
            <div class="aspect-video mb-6 overflow-hidden bg-black/5">
              <img
                src={`https://vumbnail.com/${study.vimeoId}.jpg`}
                alt={study.title}
                class="w-full h-full object-cover group-hover:opacity-80 transition-opacity"
                loading="lazy"
              />
            </div>
            <h3 class="font-display text-xl font-bold tracking-tight mb-3 group-hover:opacity-60 transition-opacity">{study.title}</h3>
            <p class="text-body mb-4">{study.description}</p>
            <span class="text-metadata text-accent group-hover:opacity-60 transition-opacity">View Case Study →</span>
          </a>
        ))}
      </div>
    </section>

    {/* Cross-links */}
    <section class="border-t border-black/10 pt-16">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <a href="/work/" class="group p-8 border border-black/10 hover:border-black/20 transition-colors">
          <span class="text-metadata mb-3 block">Work</span>
          <p class="font-display text-lg font-medium group-hover:opacity-60 transition-opacity">See all work →</p>
          <p class="text-body !text-sm mt-2">50+ projects delivered worldwide</p>
        </a>
        <a href="/process/" class="group p-8 border border-black/10 hover:border-black/20 transition-colors">
          <span class="text-metadata mb-3 block">Process</span>
          <p class="font-display text-lg font-medium group-hover:opacity-60 transition-opacity">How I work →</p>
          <p class="text-body !text-sm mt-2">Three phases. No wasted time.</p>
        </a>
        <a href="/contact/" class="group p-8 border border-black/10 hover:border-black/20 transition-colors">
          <span class="text-metadata mb-3 block">Contact</span>
          <p class="font-display text-lg font-medium group-hover:opacity-60 transition-opacity">Start a conversation →</p>
          <p class="text-body !text-sm mt-2">Quick response, no sales pitch</p>
        </a>
      </div>
    </section>
  </div>
</PageLayout>
