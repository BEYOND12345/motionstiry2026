---
import PageLayout from '../layouts/PageLayout.astro';

const structuredData = {
  "@context": "https://schema.org",
  "@type": "AboutPage",
  "name": "About Dan Neale | Motion Story",
  "url": "https://motionstory.com.au/about/",
  "speakable": {
    "@type": "SpeakableSpecification",
    "cssSelector": ["h1", ".text-body"]
  },
  "mainEntity": {
    "@type": "Person",
    "name": "Dan Neale",
    "jobTitle": "Motion Designer & Creative Director",
    "worksFor": { "@type": "Organization", "name": "Motion Story" },
    "knowsAbout": [
      "Motion Design",
      "Creative Direction",
      "Storytelling",
      "Explainer Videos",
      "Product Videos",
      "Storyboarding",
      "SaaS Marketing",
      "Agency Creative Direction"
    ],
    "sameAs": [
      "https://www.linkedin.com/in/danielneale",
      "https://vimeo.com/wearemotionstory"
    ]
  }
};
---

<PageLayout
  title="About Dan Neale | Motion Story"
  description="Dan Neale — creative director and animator. Small studio, big impact. 1,000+ films since 2010. SaaS, agencies, and complex storytelling. Byron Bay."
  activeNav="About"
  showCTA={false}
  floatSubject="About Motion Story"
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(structuredData)} />
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org", "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://motionstory.com.au/" },
        { "@type": "ListItem", "position": 2, "name": "About", "item": "https://motionstory.com.au/about/" }
      ]
    })} />
  </Fragment>

  <div class="landing">
    <header class="landing-hero">
      <span class="landing-eyebrow">About</span>
      <h1 class="landing-title">Small studio. Big impact.</h1>
      <p class="landing-lede">Skip the big production house. Work directly with a creative director who is also great on the tools — storytelling, planning, and craft for SaaS and agencies.</p>
    </header>

    <p class="landing-clients">United Nations · TransferWise · Atomic · Mosaic · RSPCA · Meltwater · Employment Hero · Wipster</p>

    <section class="landing-section">
      <div class="landing-cred">
        <div class="landing-cred-row">
          <h2 class="landing-cred-label">Career depth</h2>
          <p class="landing-cred-body">Making motion since 2010. 1,000+ films. United Nations. TransferWise's first video, working directly with their CEO. I have been making explainers since the category existed.</p>
        </div>
        <div class="landing-cred-row">
          <h2 class="landing-cred-label">Direct access</h2>
          <p class="landing-cred-body">No project manager or producer in the way. I storyboard, design, illustrate, and animate — and I own the creative direction. You get one senior maker integrated with your team, closer to a fractional creative partner than a vendor.</p>
        </div>
        <div class="landing-cred-row">
          <h2 class="landing-cred-label">Story that performs</h2>
          <p class="landing-cred-body">Clients use these films to win investment, launch products, educate employees, explain brand changes, and communicate critical updates. If the story is not strong, people do not watch to the end.</p>
        </div>
        <div class="landing-cred-row">
          <h2 class="landing-cred-label">SaaS &amp; agencies</h2>
          <p class="landing-cred-body">Primary fit: software companies (including startups) and creative agencies that want senior motion and storytelling. White label or direct. Any company size — the brief has to need clarity.</p>
        </div>
      </div>
    </section>

    <section class="landing-section">
      <span class="landing-eyebrow landing-section-label">Questions</span>
      <div class="landing-faq">
        <div class="landing-faq-row">
          <h3 class="landing-faq-label">Cost</h3>
          <p class="text-body">From $5,000. I prefer projects around $10,000–$15,000. Fixed quote upfront.</p>
        </div>
        <div class="landing-faq-row">
          <h3 class="landing-faq-label">Timeline</h3>
          <p class="text-body">Most projects take 3–6 weeks from kickoff to delivery.</p>
        </div>
        <div class="landing-faq-row">
          <h3 class="landing-faq-label">How I work</h3>
          <p class="text-body">Limited concurrent projects, on purpose. I challenge the brief before production. If you want silent execution with no questions, I am not the fit. If you want the story found and built properly, email me.</p>
        </div>
      </div>
    </section>

    <nav class="landing-links" aria-label="Related pages">
      <a href="/work/" class="landing-link-card group">
        <span class="landing-eyebrow mb-4 block">Work</span>
        <p class="landing-link-label">See all work →</p>
      </a>
      <a href="/process/" class="landing-link-card group">
        <span class="landing-eyebrow mb-4 block">Process</span>
        <p class="landing-link-label">How I work →</p>
      </a>
      <a href="/explainer-videos/" class="landing-link-card group">
        <span class="landing-eyebrow mb-4 block">Explainers</span>
        <p class="landing-link-label">Explainer videos →</p>
      </a>
    </nav>
  </div>
</PageLayout>
