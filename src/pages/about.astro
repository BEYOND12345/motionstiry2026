---
import PageLayout from '../layouts/PageLayout.astro';

const structuredData = {
  "@context": "https://schema.org",
  "@type": "AboutPage",
  "name": "About Dan Neale | Motion Story",
  "url": "https://motionstory.com.au/about/",
  "speakable": {
    "@type": "SpeakableSpecification",
    "cssSelector": ["h1", ".text-body"]
  },
  "mainEntity": {
    "@type": "Person",
    "name": "Dan Neale",
    "jobTitle": "Motion Designer & Creative Director",
    "worksFor": { "@type": "Organization", "name": "Motion Story" },
    "knowsAbout": [
      "Motion Design",
      "Creative Direction",
      "Explainer Videos",
      "Product Videos",
      "Storyboarding",
      "SaaS Marketing"
    ],
    "sameAs": [
      "https://www.linkedin.com/in/danielneale",
      "https://vimeo.com/motionstory"
    ]
  }
};
---

<PageLayout
  title="About Dan Neale | Motion Story"
  description="Dan Neale — motion designer and creative director. United Nations, TransferWise, 1,000+ films. Full pipeline: concept to animation. Byron Bay."
  activeNav="About"
  showCTA={false}
  floatSubject="About Motion Story"
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(structuredData)} />
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org", "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://motionstory.com.au/" },
        { "@type": "ListItem", "position": 2, "name": "About", "item": "https://motionstory.com.au/about/" }
      ]
    })} />
  </Fragment>

  <div class="landing">
    <header class="landing-hero">
      <span class="landing-eyebrow">About</span>
      <h1 class="landing-title">Motion design is who I am. It is all I have ever done.</h1>
      <p class="landing-lede">Dan Neale — concept, storyboard, design, illustration, and animation. One senior maker throughout.</p>
    </header>

    <p class="landing-clients">United Nations · TransferWise · Atomic · Mosaic · RSPCA · Meltwater · Employment Hero · Wipster</p>

    <section class="landing-section">
      <div class="landing-cred">
        <div class="landing-cred-row">
          <h2 class="landing-cred-label">Career depth</h2>
          <p class="landing-cred-body">United Nations. TransferWise's first video, working directly with their CEO. 1,000+ films across a career spent entirely in motion. I have been making explainers since the category existed.</p>
        </div>
        <div class="landing-cred-row">
          <h2 class="landing-cred-label">Full pipeline</h2>
          <p class="landing-cred-body">I storyboard, design, illustrate, and animate. I develop the concepts and creative direction. No account managers. No handoffs to juniors. That rare end-to-end craft is the point.</p>
        </div>
        <div class="landing-cred-row">
          <h2 class="landing-cred-label">Story that performs</h2>
          <p class="landing-cred-body">Creative execution built for completion and clarity. If the story is not strong, people do not watch to the end — and engagement metrics show it. These films are investments that sit on a site for years.</p>
        </div>
        <div class="landing-cred-row">
          <h2 class="landing-cred-label">Agencies</h2>
          <p class="landing-cred-body">I work exceptionally well with creative agencies — white label or direct. Much of the award-winning work never carries my name. That is fine. The craft does.</p>
        </div>
      </div>
    </section>

    <section class="landing-section">
      <span class="landing-eyebrow landing-section-label">Questions</span>
      <div class="landing-faq">
        <div class="landing-faq-row">
          <h3 class="landing-faq-label">Cost</h3>
          <p class="text-body">From $5,000. Most projects land around $10,000–$15,000. Fixed quote upfront.</p>
        </div>
        <div class="landing-faq-row">
          <h3 class="landing-faq-label">How I work</h3>
          <p class="text-body">Limited concurrent projects, on purpose. I challenge the brief before production. If you want silent execution with no questions, I am not the fit. If you want the story found and built properly, email me.</p>
        </div>
      </div>
    </section>

    <nav class="landing-links" aria-label="Related pages">
      <a href="/work/" class="landing-link-card group">
        <span class="landing-eyebrow mb-4 block">Work</span>
        <p class="landing-link-label">See all work →</p>
      </a>
      <a href="/process/" class="landing-link-card group">
        <span class="landing-eyebrow mb-4 block">Process</span>
        <p class="landing-link-label">How I work →</p>
      </a>
      <a href="/explainer-videos/" class="landing-link-card group">
        <span class="landing-eyebrow mb-4 block">Explainers</span>
        <p class="landing-link-label">Explainer videos →</p>
      </a>
    </nav>
  </div>
</PageLayout>
