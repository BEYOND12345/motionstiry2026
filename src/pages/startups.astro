---
import PageLayout from '../layouts/PageLayout.astro';
import ServiceLanding from '../components/ServiceLanding.astro';

const work = [
  { title: "Cart-share / Startup Explainer", link: "/casestudy/cart-share-explainer/", vimeoId: "792094835" },
  { title: "Trusyft / Product Promo", link: "/casestudy/trusyft-animated-product-promo/", vimeoId: "863428533" },
  { title: "ARK / Product Concept", link: "/casestudy/ark-product-concept/", vimeoId: "818912051" },
  { title: "Hey You / Food Ordering App", link: "/casestudy/heyyou-app/", vimeoId: "351936883" },
  { title: "Good2Pay / Paperless Invoicing", link: "/casestudy/good2pay/", vimeoId: "448704979" },
  { title: "Method / Beautiful Bin System", link: "/casestudy/method-explainer-video/", vimeoId: "557884851" },
];

const moreWork = [
  { title: "Food By Us / Kitchen Ordering", link: "/casestudy/food-by-us/", vimeoId: "672120018" },
  { title: "Uclusion / Product Decision Platform", link: "/casestudy/uclusion-product-explainer/", vimeoId: "338131381" },
  { title: "Oovvuu / WordPress Plugin", link: "/casestudy/oovvu/", vimeoId: "557000542" },
  { title: "Atomic / In-App Messaging", link: "/casestudy/atomic-in-app-messaging/", vimeoId: "861022443" },
];

const serviceSchema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "name": "Motion Design for Startups",
  "description": "Explainer and product video for early-stage and growth companies.",
  "provider": { "@type": "Organization", "name": "Motion Story", "url": "https://motionstory.com.au" },
  "serviceType": "Explainer and Product Video for Startups",
  "areaServed": "Worldwide",
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://motionstory.com.au/" },
    { "@type": "ListItem", "position": 2, "name": "Startups", "item": "https://motionstory.com.au/startups/" },
  ],
};
---

<PageLayout
  title="Explainer & Product Video for Startups | Motion Story"
  description="Explainer and product video for startups. Launch stories, homepage heroes, and demos that work before a login."
  ctaHeading="Got a product that's hard to explain?"
  ctaLabel="Start a Conversation"
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(serviceSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
  </Fragment>

  <ServiceLanding
    eyebrow="Startups"
    headline={["Make the idea land", "before the login."]}
    lede="Explainers and product videos for early-stage teams — clear enough for a cold visitor, sharp enough for investors."
    answer="Explainer and product video for startups — homepage heroes, waitlist stories, and demos that land before the login."
    work={work}
    moreWork={moreWork}
    quote="62% completion rate. 21% view rate. Long-term asset for our business."
    quoteBy="Lee Bright"
    quoteRole="Marketing Lead, Method Recycling"
    faqs={[
      { label: "Fit for startups", body: "Homepage heroes, waitlist videos, investor updates, and the first product story that has to work cold." },
      { label: "How we work", body: "You work directly with Dan — script, design, and animation. No account managers, no handoffs." },
    ]}
    links={[
      { href: "/explainer-videos/", eyebrow: "Explainers", label: "Explainer videos →" },
      { href: "/product-demo-videos/", eyebrow: "Demos", label: "Product demo videos →" },
      { href: "/contact/", eyebrow: "Next", label: "Start a project →" },
    ]}
  />
</PageLayout>
