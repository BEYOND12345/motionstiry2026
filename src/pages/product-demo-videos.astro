---
import PageLayout from '../layouts/PageLayout.astro';
import ServiceLanding from '../components/ServiceLanding.astro';

const work = [
  { title: "Trudi / AI Property Management", link: "/casestudy/property-management-explainer-video/", vimeoId: "866174146" },
  { title: "Wipster / Video Feedback Tool", link: "/casestudy/wipster-product-overview/", vimeoId: "648360270" },
  { title: "Atomic / In-App Messaging", link: "/casestudy/atomic-in-app-messaging/", vimeoId: "861022443" },
  { title: "Mosaic / Strategic Data Planning", link: "/casestudy/mosaic-platform-explained/", vimeoId: "879242129" },
  { title: "Good2Pay / Paperless Invoicing", link: "/casestudy/good2pay/", vimeoId: "448704979" },
  { title: "InfoView / Digital Expense Management", link: "/casestudy/infoview/", vimeoId: "404852749" },
];

const moreWork = [
  { title: "Class Trust / Accounting Software", link: "/casestudy/class-trust-motion-graphic-explainer/", vimeoId: "485803845" },
  { title: "DRIV0 / Carpark Management", link: "/casestudy/driv0/", vimeoId: "394074132" },
  { title: "Acodis / AI Document Processing", link: "/casestudy/acodis/", vimeoId: "580088673" },
  { title: "Hey You / Food Ordering App", link: "/casestudy/heyyou-app/", vimeoId: "351936883" },
];

const serviceSchema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "name": "Product Demo Videos",
  "description": "Animated product demo videos that show your software in action. Turn complex features into clear walkthroughs.",
  "provider": { "@type": "Organization", "name": "Motion Story", "url": "https://motionstory.com.au" },
  "serviceType": "Product Demo Video Production",
  "areaServed": "Worldwide",
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://motionstory.com.au/" },
    { "@type": "ListItem", "position": 2, "name": "Product Demo Videos", "item": "https://motionstory.com.au/product-demo-videos/" },
  ],
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    { "@type": "Question", "name": "How much does a product demo video cost?", "acceptedAnswer": { "@type": "Answer", "text": "From $5,000. Most projects land around $10,000–$15,000. Fixed quote upfront." } },
    { "@type": "Question", "name": "What's the difference between an animated product demo and a screen recording?", "acceptedAnswer": { "@type": "Answer", "text": "An animated product demo is crafted motion design that shows your software at its best. You control pacing and narrative — and it doesn't break every time your UI changes." } },
    { "@type": "Question", "name": "What's the difference working with Motion Story?", "acceptedAnswer": { "@type": "Answer", "text": "You work with Dan throughout — concept, storyboard, design, illustration, and animation. No account managers, no handoffs." } },
  ],
};
---

<PageLayout
  showCTA={false}
  title="Product Demo Videos | Motion Story"
  description="Animated product demo videos that show your software in action — no login required. Built for landing pages, sales decks, and onboarding."
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(serviceSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  </Fragment>

  <ServiceLanding
    eyebrow="Product Demo Videos"
    headline={["Your product does incredible things.", "Nobody's seeing it."]}
    lede="Animated demos that show your software working, clearly, without a login."
    emailSubject="Product demo video"
    work={work}
    moreWork={moreWork}
    quote="62% completion rate. 21% view rate. This will be a long-term asset for our business."
    quoteBy="Lee Bright"
    quoteRole="Marketing Lead, Method Recycling"
    faqs={[
      { label: "Cost", body: "From $5,000. Most projects land around $10,000–$15,000. Fixed quote upfront." },
      { label: "vs screen recording", body: "Animated demos stay polished when your UI changes. You control the story." },
      { label: "How we work", body: "You work with Dan throughout — concept, storyboard, design, illustration, and animation. Agencies welcome, white label or direct." },
    ]}
    links={[
      { href: "/saas-explainer-videos/", eyebrow: "SaaS", label: "SaaS explainer videos →" },
      { href: "/technology-videos/", eyebrow: "Tech", label: "Technology videos →" },
      { href: "/work/", eyebrow: "Work", label: "See all work →" },
    ]}
  />
</PageLayout>
