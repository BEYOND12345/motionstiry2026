---
import PageLayout from '../layouts/PageLayout.astro';
import ServiceLanding from '../components/ServiceLanding.astro';

const work = [
  { title: "Mosaic / Strategic Data Planning", link: "/casestudy/mosaic-platform-explained/", vimeoId: "879242129" },
  { title: "Atomic / In-App Messaging", link: "/casestudy/atomic-in-app-messaging/", vimeoId: "861022443" },
  { title: "Acodis / AI Document Processing", link: "/casestudy/acodis/", vimeoId: "580088673" },
  { title: "Trudi / AI Property Management", link: "/casestudy/property-management-explainer-video/", vimeoId: "866174146" },
  { title: "Wipster / Video Feedback Tool", link: "/casestudy/wipster-product-overview/", vimeoId: "648360270" },
  { title: "Good2Pay / Paperless Invoicing", link: "/casestudy/good2pay/", vimeoId: "448704979" },
];

const moreWork = [
  { title: "InfoView / Digital Expense Management", link: "/casestudy/infoview/", vimeoId: "404852749" },
  { title: "Class Trust / Accounting Software", link: "/casestudy/class-trust-motion-graphic-explainer/", vimeoId: "485803845" },
  { title: "Giraffe / Designing Cities", link: "/casestudy/giraffe/", vimeoId: "762112642" },
  { title: "Shape Connect / Website Security", link: "/casestudy/shape-connect/", vimeoId: "320632556" },
];

const serviceSchema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "name": "SaaS Explainer Videos",
  "description": "SaaS explainer videos that turn complex software into clear, compelling stories. Product demos, platform explainers, and onboarding animation.",
  "provider": { "@type": "Organization", "name": "Motion Story", "url": "https://motionstory.com.au" },
  "serviceType": "SaaS Explainer Video Production",
  "areaServed": "Worldwide",
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://motionstory.com.au/" },
    { "@type": "ListItem", "position": 2, "name": "SaaS Explainer Videos", "item": "https://motionstory.com.au/saas-explainer-videos/" },
  ],
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    { "@type": "Question", "name": "How much does a SaaS explainer video cost?", "acceptedAnswer": { "@type": "Answer", "text": "Most SaaS explainer videos range from $8,000 to $25,000 depending on length and complexity. Every project is scoped individually." } },
    { "@type": "Question", "name": "How long does a SaaS explainer take?", "acceptedAnswer": { "@type": "Answer", "text": "Typical turnaround is 4 to 6 weeks from kickoff to final delivery." } },
    { "@type": "Question", "name": "What's the difference working with Motion Story?", "acceptedAnswer": { "@type": "Answer", "text": "You work directly with Dan — the person writing, designing, and animating — throughout the project. No account managers, no handoffs." } },
  ],
};
---

<PageLayout
  title="SaaS Explainer Videos | Motion Story"
  description="SaaS explainer videos for complex software. Clear product stories for sales, onboarding, and landing pages. Work directly with Dan."
  ctaHeading="Got a SaaS product that's hard to explain?"
  ctaLabel="Start a Conversation"
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(serviceSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  </Fragment>

  <ServiceLanding
    eyebrow="SaaS Explainer Videos"
    headline={["Your software is invisible.", "Your explainer shouldn't be."]}
    lede="SaaS explainers that show what your product does — before the sales call."
    answer="SaaS explainer videos for product teams — platform stories, homepage heroes, and onboarding motion that make complex software obvious before the demo."
    work={work}
    moreWork={moreWork}
    quote="40,000 views on YouTube, which increased brand perception and reputation."
    quoteBy="Simon Lehman"
    quoteRole="Marketing Manager, Acodis"
    faqs={[
      { label: "Cost", body: "Typically $8,000–$25,000 depending on length and complexity. Fixed quote per project." },
      { label: "Timeline", body: "Most SaaS explainers take 4–6 weeks from kickoff to final delivery." },
      { label: "How we work", body: "You work directly with Dan — script, design, and animation. No account managers, no handoffs." },
    ]}
    links={[
      { href: "/product-demo-videos/", eyebrow: "Demos", label: "Product demo videos →" },
      { href: "/technology-videos/", eyebrow: "Tech", label: "Technology videos →" },
      { href: "/contact/", eyebrow: "Next", label: "Start a project →" },
    ]}
  />
</PageLayout>
